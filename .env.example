# Journal Data API Configuration
# Copy to .env and fill in your values

# CrossRef polite pool email (recommended for higher rate limits)
JOURNAL_CROSSREF_EMAIL=your.email@example.com

# Unpaywall email (required for API access)
JOURNAL_UNPAYWALL_EMAIL=your.email@example.com

# OpenAlex API key (optional, for higher rate limits)
JOURNAL_OPENALEX_API_KEY=

# Semantic Scholar API key (optional, for higher rate limits)
JOURNAL_SEMANTIC_SCHOLAR_API_KEY=

# Campus proxy URL for institutional access (SOCKS5 or HTTP)
# Example: socks5://proxy.example.edu:1080
JOURNAL_CAMPUS_PROXY_URL=

# Cache directory
JOURNAL_CACHE_DIR=.cache/journal_api

# Log level
JOURNAL_LOG_LEVEL=INFO

# API server
JOURNAL_API_HOST=0.0.0.0
JOURNAL_API_PORT=8000
