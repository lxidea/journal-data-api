# Journal Data API Configuration (YAML)
# Copy to config.yaml. Environment variables override these values.

crossref_email: "your.email@example.com"
unpaywall_email: "your.email@example.com"
openalex_api_key: ""
semantic_scholar_api_key: ""

# Campus proxy for institutional access (SOCKS5 or HTTP)
# Example: socks5://proxy.example.edu:1080
campus_proxy_url: ""

scihub_mirrors:
  - "https://sci-hub.se"
  - "https://sci-hub.st"
  - "https://sci-hub.ru"

cache_dir: ".cache/journal_api"
metadata_ttl_days: 30

# Rate limits (requests per second)
rate_crossref: 50.0
rate_openalex: 10.0
rate_semantic_scholar: 5.0
rate_unpaywall: 10.0
rate_scihub: 0.33
rate_google_scholar: 0.1
rate_publisher_proxy: 2.0

api_host: "0.0.0.0"
api_port: 8000
log_level: "INFO"
